{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ken",
  "version": "0.1.1",
  "identifier": "dev.smokey.ken",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ken",
        "dragDropEnabled": false,
        "width": 1320,
        "height": 840,
        "minWidth": 980,
        "minHeight": 620,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#F6F4EF"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/ken-mcp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFOTI3OTJCRTZGN0M5MDkKUldRSnlmZm1LM21TSHIzMFVPMUl0VUo2RXpSMlBxcC9NUW9vZ2tMTVZvK1l6TWRWY3RUNldNZGQK",
      "endpoints": [
        "https://github.com/smo-key/ken/releases/latest/download/latest.json"
      ]
    }
  }
}
